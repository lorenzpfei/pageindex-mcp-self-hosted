# LLM key used during ingest (tree building + vision OCR). The default model
# is gemini/gemini-3.5-flash, so a Gemini key is required unless you switch
# PAGEINDEX_MODEL / PAGEINDEX_OCR_MODEL to another LiteLLM provider.
GEMINI_API_KEY=
#OPENAI_API_KEY=

# Bearer token required by clients connecting to the MCP server.
# Generate e.g. with: openssl rand -hex 32
PAGEINDEX_MCP_API_KEY=

# Optional: LLM used for tree-building (any LiteLLM model id, e.g.
# gpt-4o-2024-11-20 or anthropic/claude-haiku-4-5). Empty = the
# pageindex/config.yaml default (gemini/gemini-3.5-flash).
#PAGEINDEX_MODEL=

# Optional: vision model that transcribes pages with little/no extractable
# text (scans, image-heavy slides). Set to "off" to disable OCR.
#PAGEINDEX_OCR_MODEL=gemini/gemini-3.5-flash

# Optional: parallel PDF ingests (default 2). Each one holds the PDF + tree
# in memory and already parallelizes its LLM calls internally, so high
# values mostly burn RAM and OpenAI rate limits.
#PAGEINDEX_INGEST_WORKERS=2
