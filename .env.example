# LLM key used for PageIndex tree-building (ingest.py). LiteLLM-compatible,
# OpenAI is the default model in pageindex/config.yaml.
OPENAI_API_KEY=

# Bearer token required by clients connecting to the MCP server.
# Generate e.g. with: openssl rand -hex 32
PAGEINDEX_MCP_API_KEY=

# Optional: LLM used for tree-building (any LiteLLM model id, e.g.
# gpt-5-mini or anthropic/claude-haiku-4-5). Empty = pageindex/config.yaml
# default (gpt-4o-2024-11-20, the model upstream's prompts are tuned for).
#PAGEINDEX_MODEL=

# Optional: parallel PDF ingests (default 2). Each one holds the PDF + tree
# in memory and already parallelizes its LLM calls internally, so high
# values mostly burn RAM and OpenAI rate limits.
#PAGEINDEX_INGEST_WORKERS=2
